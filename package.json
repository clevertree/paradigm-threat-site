{
  "name": "paradigm-threat-site",
  "version": "2.0.5",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predev": "true",
    "build": "next build --webpack",
    "export": "next export",
    "start": "next start -p 8081",
    "build-start": "next build && next start -p 8081",
    "cypress:component": "cypress run --component",
    "cypress:e2e": "cypress run --e2e",
    "cypress:e2e:prod": "CYPRESS_BASE_URL=http://localhost:8081 cypress run --e2e",
    "cypress:open": "cypress open",
    "cypress-prod:run": "CYPRESS_BASE_URL=https://paradigmthreat.net cypress run",
    "lint": "next lint",
    "standard": "npx standard --fix",
    "prepare": "husky install"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.1.6",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^1.6.1",
    "@vercel/postgres": "^0.10.0",
    "@vercel/speed-insights": "^1.3.1",
    "autoprefixer": "^10.4.27",
    "crc-32": "^1.2.2",
    "dotenv": "^16.6.1",
    "eslint-config-next": "^16.1.6",
    "framer-motion": "^12.36.0",
    "gray-matter": "^4.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "markdown-to-jsx": "^7.7.17",
    "mime": "^3.0.0",
    "next": "^16.1.6",
    "next-mdx-remote": "^6.0.0",
    "paradigm-threat-animation": "workspace:*",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-unwrap-images": "^1.0.0",
    "remark-gfm": "^4.0.1",
    "sass": "^1.98.0",
    "sharp": "^0.32.6",
    "simple-git": "^3.33.0",
    "tailwindcss": "^3.4.19",
    "three": "^0.183.2",
    "typescript": "^5.9.3",
    "vis-timeline": "^8.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@types/leaflet": "^1.9.21",
    "@types/mime": "^3.0.4",
    "@types/prop-types": "^15.7.15",
    "@types/three": "^0.183.1",
    "cypress": "^15.11.0",
    "eslint": "^9.39.4",
    "eslint-plugin-chai-friendly": "^0.7.4",
    "eslint-plugin-cypress": "^2.15.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^8.0.3",
    "standard": "^17.1.2"
  },
  "standard": {
    "globals": [
      "fetch",
      "expect",
      "describe",
      "context",
      "it",
      "cy"
    ]
  },
  "resolutions": {
    "string-width": "4.2.3"
  },
  "ignorePatterns": [
    "**/*.cy.js"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "cypress",
      "@parcel/watcher",
      "bufferutil",
      "unrs-resolver"
    ]
  }
}